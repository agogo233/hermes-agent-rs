# ----- Dependency cache stage -----
FROM rust:1-bookworm AS deps
ARG CARGO_NET_RETRY=3
WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY crates crates

# Create dummy source files for all workspace crates so cargo can resolve & compile deps
RUN mkdir -p \
      crates/hermes-acp/src \
      crates/hermes-agent/src \
      crates/hermes-bus/src \
      crates/hermes-cli/src \
      crates/hermes-config/src \
      crates/hermes-core/src \
      crates/hermes-cron/src \
      crates/hermes-environments/src \
      crates/hermes-eval/src \
      crates/hermes-gateway/src \
      crates/hermes-intelligence/src \
      crates/hermes-mcp/src \
      crates/hermes-parity-tests/src \
      crates/hermes-server/src \
      crates/hermes-skills/src \
      crates/hermes-telemetry/src \
      crates/hermes-tools/src \
      crates/hermes-transport/src \
    && for crate in crates/*/; do \
         name="$(basename "$crate")"; \
         touch "${crate}src/lib.rs"; \
         if [ "$name" = "hermes-cli" ] || [ "$name" = "hermes-server" ]; then \
           echo "fn main() {}" > "${crate}src/main.rs"; \
         fi; \
       done

RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/app/target \
    cargo build --release -p hermes-cli 2>/dev/null; true

# ----- Build stage -----
FROM rust:1-bookworm AS builder
ARG CARGO_NET_RETRY=3
WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY crates crates

RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/app/target \
    cargo build --release -p hermes-cli \
    && strip /app/target/release/hermes

# ----- Runtime stage -----
FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --shell /bin/bash hermes

COPY --from=builder /app/target/release/hermes /usr/local/bin/hermes

LABEL org.opencontainers.image.source="https://github.com/nousresearch/hermes-engine" \
      org.opencontainers.image.description="Hermes Agent - AI agent runtime" \
      org.opencontainers.image.licenses="MIT"

USER hermes
ENV HERMES_HOME=/data
VOLUME ["/data"]

HEALTHCHECK --interval=60s --timeout=5s --retries=3 \
    CMD hermes doctor || exit 1

ENTRYPOINT ["hermes"]